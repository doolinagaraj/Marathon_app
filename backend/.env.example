NODE_ENV=development
PORT=4000

JWT_SECRET=change_me_in_prod
JWT_EXPIRES_IN=7d

# This is overridden by docker-compose to point at the mongo container.
MONGODB_URI=mongodb://localhost:27017/marathon

FRONTEND_ORIGIN=http://localhost:5173
# Optional comma-separated allowlist for additional frontend origins
# Example: FRONTEND_ORIGINS=https://doolinagaraj.github.io,https://myapp.com
FRONTEND_ORIGINS=

# Optional: make an existing user admin on boot (one-time helper)
BOOTSTRAP_ADMIN_EMAIL=

# Optional: seed an admin user on boot (do NOT commit real creds)
ADMIN_SEED_EMAIL=
ADMIN_SEED_PASSWORD=

# Email (optional). If unset, backend will skip sending but still return success.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Marathon App <no-reply@example.com>"

# Web Push (optional)
VAPID_SUBJECT="mailto:no-reply@example.com"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
